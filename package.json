{
  "name": "ccem-monorepo",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Claude Code Environment Manager - Monorepo",
  "author": {
    "name": "Genuifx",
    "email": "genuifx@gmail.com",
    "url": "https://genuifx.com"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "runtime:spike": "bash scripts/runtime/claude-protocol-spike.sh",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "test:coverage": "pnpm -r test:coverage",
    "audit:prod:high": "node scripts/ci/check-prod-audit.mjs",
    "check:i18n": "node scripts/check-i18n.js",
    "check:file-size": "bash scripts/check-file-size.sh",
    "check:release-version": "node scripts/ci/check-release-version.mjs",
    "check:all": "pnpm check:i18n && pnpm check:file-size",
    "verify": "pnpm audit:prod:high && pnpm test:run && pnpm build && cd apps/desktop/src-tauri && cargo test",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-version.js",
    "release": "pnpm build && pnpm test:run && pnpm changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@tauri-apps/cli": "^2.9.6",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.27",
      "@types/react-dom": "18.3.7",
      "@xmldom/xmldom": "0.8.13",
      "fast-uri": "3.1.2",
      "hono": "4.12.27",
      "js-cookie": "3.0.8",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "ws": "8.21.0"
    }
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
