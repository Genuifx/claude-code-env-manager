{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCEM Desktop",
  "version": "2.1.0",
  "identifier": "com.ccem.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CCEM Desktop",
        "width": 900,
        "height": 700,
        "minWidth": 880,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; script-src 'self' 'wasm-unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/ccem-node"
    ],
    "resources": [
      "resources/native-runtime-helper.mjs"
    ],
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Claude Code Environment Manager",
    "longDescription": "A desktop application for managing Claude Code API environments and permission modes.",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzQjI2MkY1ODY2NTkyRkYKUldUL2ttV0c5V0t5ODJoVkJqdUFhc2NNUjJtZVJjMDVwUWNtVktOdXkwREgzaTgyRVVVaVg1UUwK",
      "endpoints": [
        "https://github.com/Genuifx/claude-code-env-manager/releases/latest/download/latest.json"
      ]
    }
  }
}
