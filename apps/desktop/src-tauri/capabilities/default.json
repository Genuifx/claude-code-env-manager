{
  "identifier": "default",
  "description": "Default capabilities for CCEM Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-save",
    "notification:default",
    "mcp-bridge:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
